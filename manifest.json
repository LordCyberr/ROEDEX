{
  "manifest_version": 3,
  "name": "ROEDEX: Ultimate Overlay Tracker",
  "version": "1.0.1",
  "description": "The definitive real-time farming, session tracking, and analytics overlay for Roots of Embervault.",
  "icons": {
    "16": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": "icon128.png",
    "default_title": "ROEDEX Overlay"
  },
  "content_scripts": [
    {
      "js": ["src/main.tsx"],
      "matches": ["*://embervault.ruyui.com/*"]
    },
    {
      "js": ["src/core/websocket/interceptor.ts"],
      "matches": ["*://embervault.ruyui.com/*"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
