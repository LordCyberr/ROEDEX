{
  "manifest_version": 3,
  "name": "ROEDEX",
  "version": "0.0.1",
  "description": "Real-time overlay for Roots of Embervault! Live loot tracking, spawn timers, categorized NPC locations, and multi-language support.",
  "icons": {
    "16": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": "icon128.png",
    "default_title": "ROEDEX Overlay"
  },
  "content_scripts": [
    {
      "js": [
        "src/main.tsx"
      ],
      "matches": [
        "*://embervault.ruyui.com/*"
      ]
    },
    {
      "js": [
        "src/core/websocket/interceptor.ts"
      ],
      "matches": [
        "*://embervault.ruyui.com/*"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icon128.png",
        "logo.png",
        "assets/*"
      ],
      "matches": [
        "*://embervault.ruyui.com/*"
      ]
    }
  ]
}